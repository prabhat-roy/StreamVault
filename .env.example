# ============================================================
# Project-wide local development environment.
# Copy to .env and adjust per developer.
# .env is gitignored — never commit real credentials.
# ============================================================

# ----- General -----
ENV=development
LOG_LEVEL=debug
SERVICE_DOMAIN=localhost

# ----- PostgreSQL (subscription, billing, user) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=streamvault
POSTGRES_PASSWORD=streamvault
POSTGRES_DB=streamvault

# ----- MongoDB (catalogue) -----
MONGO_URI=mongodb://localhost:27017
MONGO_DB=catalogue

# ----- Redis (session, recently watched, leaderboards, rate limit) -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- Cassandra (playback events, view history) -----
CASSANDRA_CONTACT_POINTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=streamvault_playback

# ----- Elasticsearch (catalogue search) -----
ELASTICSEARCH_URL=http://localhost:9200

# ----- ClickHouse (QoE / engagement / ad analytics) -----
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=streamvault_analytics

# ----- Kafka (domain events) -----
KAFKA_BROKERS=localhost:9092
KAFKA_SCHEMA_REGISTRY=http://localhost:8081

# ----- NATS JetStream (live signalling, watch-party) -----
NATS_URL=nats://localhost:4222

# ----- Object storage (MinIO / S3 — mezzanine + segments) -----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_MEZZANINE=streamvault-mezzanine
S3_BUCKET_SEGMENTS=streamvault-segments

# ----- CDN (Cloudflare / CloudFront) -----
CDN_BASE_URL=https://cdn.streamvault.local
CDN_PURGE_TOKEN=change-me

# ----- DRM (Vault HSM-backed) -----
WIDEVINE_LICENCE_URL=http://localhost:50031/widevine
FAIRPLAY_LICENCE_URL=http://localhost:50031/fairplay
PLAYREADY_LICENCE_URL=http://localhost:50031/playready

# ----- OpenTelemetry -----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=local

# ----- Auth (Keycloak / OIDC) -----
OIDC_ISSUER_URL=http://localhost:8080/realms/streamvault
OIDC_CLIENT_ID=streamvault
OIDC_CLIENT_SECRET=change-me

# ----- Vault (DRM keys live in HSM-backed Vault transit) -----
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root
VAULT_TRANSIT_KEY_DRM=streamvault-drm

# ----- Feature flags (Unleash) -----
UNLEASH_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=

# ----- Observability backends -----
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
LOKI_URL=http://localhost:3100
JAEGER_URL=http://localhost:16686

# ----- Playback SLO targets -----
SLO_JOIN_TIME_P95_MS=2000
SLO_LIVE_LATENCY_P95_MS=3000
SLO_REBUFFER_RATIO_MAX=0.005
