.PHONY: build test run lint tidy docker-build

build:
	go build -o bin/targeting-service .

test:
	go test ./... -v -race

run:
	go run .

tidy:
	go mod tidy

lint:
	golangci-lint run ./...

docker-build: tidy
	docker build -t streamvault/targeting-service:latest .

docker-run:
	docker run --rm -p 50222:50222 --env-file .env streamvault/targeting-service:latest
